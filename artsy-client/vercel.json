{
  "rewrites": [
    {
      "source": "/socket.io/:path*",
      "destination": "https://artsy-dublin-website.up.railway.app/socket.io/:path*"
    },
    {
      "source": "/(ad-.*)",
      "destination": "https://artsy-dublin-website.up.railway.app/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}